# ====================================
# DATABASE CONFIGURATION
# ====================================

# For Development (SQLite)
# DATABASE_URL=sqlite+aiosqlite:///./cost_estimator.db

# For Production (PostgreSQL)
# Replace with your actual PostgreSQL credentials
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/cost_estimator
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/cost_estimator

# Database Connection Pool Settings (PostgreSQL only)
# These settings optimize connection pooling for better performance
DB_POOL_SIZE=20          # Maximum number of connections in the pool
DB_MAX_OVERFLOW=10       # Additional connections allowed beyond pool_size
DB_POOL_TIMEOUT=30       # Seconds to wait for connection from pool
DB_POOL_RECYCLE=3600     # Seconds before recycling connections (1 hour)

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# AI Providers
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
AI_PROVIDER=groq
GROQ_MODEL_LARGE=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# File Storage (local for MVP, swap to azure/s3 later)
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_CONTAINER_NAME=cost-estimator
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET_NAME=
# AWS_REGION=

# App
APP_NAME=CostEstimatorAgent
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Company Branding (for cover letters)
COMPANY_NAME=Your Engineering Company
COMPANY_ADDRESS=123 Industrial Zone, City, Country
COMPANY_PHONE=+1-234-567-8900
COMPANY_EMAIL=info@yourcompany.com
COMPANY_WEBSITE=www.yourcompany.com
SIGNATORY_NAME=Project Manager
SIGNATORY_TITLE=Head of Fabrication
